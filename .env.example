# Salon Amira — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# MySQL root password
MYSQL_ROOT_PASSWORD=change_this_value

# MySQL user password
MYSQL_PASSWORD=change_this_value

# Database URL (MySQL connection)
DATABASE_URL=mysql+pymysql://booking:change_this_value@db:3306/booking

# Admin dashboard password
ADMIN_PASSWORD=change_this_value
